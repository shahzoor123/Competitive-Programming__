    {
      "type": "text",
      "version": 951,
      "versionNonce": 2080996189,
      "index": "asl",
      "isDeleted": false,
      "id": "DH4EZabuYtdOVnJiII7w2",
      "fillStyle": "solid",
      "strokeWidth": 2,
