    {
      "id": "5cHArhs07HB5NcGfPXr7J",
      "type": "text",
      "x": -72.88690821592604,
      "y": 562.4160863233615,
      "width": 1362.5336442507928,
      "height": 470.8787302231469,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#4dabf7",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b05",
      "roundness": null,
      "seed": 1783533981,
      "version": 217,
      "versionNonce": 107723069,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1722079875426,
      "link": null,
      "locked": false,
      "text": "Initialize two pointers, slow and fast, both pointing to the head of the linked list.\n\nMove slow one step and fast two steps at a time until fast reaches the end, making slow point to the middle of the list.\n\nInitialize prev to None and current to the node after slow.\n\nReverse the second half by iterating through nodes using a while loop where current is not None,\n updating current's next to prev, and moving prev and current forward.\n\nSet the head of the second half to prev, which is now the reversed second half's head.\n\nInitialize max_twin_sum to 0 and set left and right pointers to the head and reversed head of the second half, respectively.\n\nTraverse through both halves of the list simultaneously, calculating the twin sum as the sum\n of left.val and right.val, updating max_twin_sum with the maximum twin sum found.\n\nReturn max_twin_sum as the result of the maximum twin sum of the linked list.",
      "fontSize": 22.158999069324565,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Initialize two pointers, slow and fast, both pointing to the head of the linked list.\n\nMove slow one step and fast two steps at a time until fast reaches the end, making slow point to the middle of the list.\n\nInitialize prev to None and current to the node after slow.\n\nReverse the second half by iterating through nodes using a while loop where current is not None,\n updating current's next to prev, and moving prev and current forward.\n\nSet the head of the second half to prev, which is now the reversed second half's head.\n\nInitialize max_twin_sum to 0 and set left and right pointers to the head and reversed head of the second half, respectively.\n\nTraverse through both halves of the list simultaneously, calculating the twin sum as the sum\n of left.val and right.val, updating max_twin_sum with the maximum twin sum found.\n\nReturn max_twin_sum as the result of the maximum twin sum of the linked list.",
      "autoResize": true,
      "lineHeight": 1.25
    },
