      "boundElements": null,
      "updated": 1722079748578,
      "link": null,
      "locked": false,
      "fontSize": 22.85714285714286,
      "fontFamily": 5,
      "text": "1 - Find the mid point using pointers \n\n2 - reverse the second half of the list just because we \n    cannot traverse linked list inwards using pointers\n\n3 - so can go from left to right but not right to left \n    so thats why reverse the second half so that we can \n    traverse through that as well inwards",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1 - Find the mid point using pointers \n\n2 - reverse the second half of the list just because we \n    cannot traverse linked list inwards using pointers\n\n3 - so can go from left to right but not right to left \n    so thats why reverse the second half so that we can \n    traverse through that as well inwards",
      "autoResize": true,
      "lineHeight": 1.25
    },
