      "updated": 1722079010542,
      "link": null,
      "locked": false,
      "fontSize": 22.85714285714286,
      "fontFamily": 5,
      "text": "1 - Dump all these values in an array\n\n2 - Then use 2 pointer on that array\n\n3 - to sum the twins and find the max\n\n4 - Again convert to linked list",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1 - Dump all these values in an array\n\n2 - Then use 2 pointer on that array\n\n3 - to sum the twins and find the max\n\n4 - Again convert to linked list",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "type": "text",
      "version": 441,
      "versionNonce": 1212805811,
      "index": "asV",
