    {
      "id": "teaQlCUUHc38oRa1XC49j",
      "type": "text",
      "x": 3589.05746091011,
      "y": 286.7399079874396,
      "width": 361.44518662022494,
      "height": 36.10554137514282,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0M",
      "roundness": null,
      "seed": 1940924716,
      "version": 180,
      "versionNonce": 1533892268,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1721858182286,
      "link": null,
      "locked": false,
      "text": "Traverse the linked list and push each node onto \na stack until you have k nodes.",
      "fontSize": 14.442216550057124,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Traverse the linked list and push each node onto a stack until you have k nodes.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "SZQ6N4qhaVR9ZLw5RI0b6",
      "type": "text",
      "x": 3588.7768087031172,
      "y": 337.63751288587105,
      "width": 364.2721354127163,
      "height": 37.06474210090837,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0N",
      "roundness": null,
      "seed": 2107854740,
      "version": 199,
      "versionNonce": 1202763284,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1721858178902,
      "link": null,
      "locked": false,
      "text": "Pop nodes from the stack and reconnect them in \nreversed order.",
      "fontSize": 14.825896840363352,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Pop nodes from the stack and reconnect them in reversed order.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "NNfyOFAr6n8OshQIXXw0C",
      "type": "text",
      "x": 3587.926094562069,
      "y": 383.8810053182517,
      "width": 326.8230938872206,
      "height": 48.882708071003634,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0O",
      "roundness": null,
      "seed": 480912300,
      "version": 171,
      "versionNonce": 873279532,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1721858175505,
      "link": null,
      "locked": false,
      "text": "Continue this process until there are fewer than k\nnodes left, leaving the remaining nodes as they \nare.",
      "fontSize": 13.035388818934297,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Continue this process until there are fewer than k nodes left, leaving the remaining nodes as they are.",
      "autoResize": false,
      "lineHeight": 1.25
    },
