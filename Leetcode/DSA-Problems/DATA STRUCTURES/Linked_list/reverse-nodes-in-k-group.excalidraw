      "versionNonce": 1797502100,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1721853984186,
      "link": null,
      "locked": false,
      "text": "So the problem demands reverse the node in k - Group means  :\n\n1 - we have to find all k - group nodes then reverse them\n\n2 - if any node remains in the end which is not making a k len group attach it as it is",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "So the problem demands reverse the node in k - Group means  :\n\n1 - we have to find all k - group nodes then reverse them\n\n2 - if any node remains in the end which is not making a k len group attach it as it is",
      "autoResize": true,
      "lineHeight": 1.25
    },
